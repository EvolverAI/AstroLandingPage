---
import { resolveImage } from "../../utils/images.js";
import ResponsiveImage from "../ResponsiveImage.astro";

export interface FeatureItem {
  text: string;
  icon?: string;
  iconColor?: string;
}

export interface Props {
  sectionId: string;
  sectionType?: string;
  title?: string;
  subtitle?: string;
  description?: string;
  features?: FeatureItem[];
  buttonText?: string;
  buttonUrl?: string;
  buttonColor?: string;
  image?: string;
  imageAlt?: string;
  useIconInstead?: boolean;
  iconName?: string;
  iconGradient?: string;
  imagePosition?: string;
  customClasses?: string;
  language?: string;
}

const {
  sectionId,
  sectionType = sectionId,
  title = "",
  subtitle = "",
  description = "",
  features = [],
  buttonText,
  buttonUrl,
  buttonColor = "bg-blue-600 hover:bg-blue-700",
  image,
  imageAlt = "",
  useIconInstead = false,
  iconName = "smart_toy",
  iconGradient = "from-purple-600 to-blue-600",
  imagePosition = "right",
  customClasses = "",
  language = "en",
} = Astro.props;

const cleanDescription = description
  ? description
      .replace(/[\r\n]+/g, " ")
      .replace(/\s+/g, " ")
      .trim()
  : "";

const resolvedImage = image ? resolveImage(image) : null;
const isImageLeft = imagePosition === "left";
const textOrder = isImageLeft ? "order-2 md:order-2" : "order-2 md:order-1";
const imageOrder = isImageLeft ? "order-1 md:order-1" : "order-1 md:order-2";
---

<section
  id={sectionId}
  class={`relative section-product py-20 ${customClasses}`}
  data-section={sectionType}
>
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <!-- Text -->
      <div class={`${textOrder} reveal-left`}>
        <h2 class="h1-noto-sans mb-4">{subtitle}</h2>
        <p class="text-slate-300 text-lg leading-relaxed mb-8">
          {cleanDescription}
        </p>

        {
          features.length > 0 && (
            <ul class="space-y-3 mb-8">
              {features.map((f) => (
                <li class="flex items-start gap-3 text-slate-300">
                  <span
                    class={`material-icons ${f.iconColor || "text-green-400"} mt-0.5 shrink-0`}
                  >
                    {f.icon || "check_circle"}
                  </span>
                  {f.text}
                </li>
              ))}
            </ul>
          )
        }

        {
          buttonText && buttonUrl && (
            <a href={buttonUrl} class={`btn ${buttonColor} text-white`}>
              {buttonText}
            </a>
          )
        }
      </div>

      <!-- Image -->
      <div class={`${imageOrder} reveal-right`}>
        {
          useIconInstead ? (
            <div
              class={`bg-gradient-to-br ${iconGradient} rounded-full w-32 h-32 flex items-center justify-center mx-auto`}
            >
              <span class="material-icons text-white text-5xl">{iconName}</span>
            </div>
          ) : resolvedImage ? (
            <div class="product-img-wrap">
              <ResponsiveImage
                src={resolvedImage}
                alt={imageAlt || subtitle}
                class="w-full h-full object-cover"
                loading={imagePosition === "right" ? "eager" : "lazy"}
                fetchpriority={imagePosition === "right" ? "high" : "auto"}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
            </div>
          ) : (
            <div class="product-img-wrap flex items-center justify-center">
              <span class="material-icons text-slate-600 text-6xl">image</span>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .section-product {
    background: linear-gradient(135deg, #0a0f1e 0%, #0f172a 50%, #0a0f1e 100%);
  }

  :global([data-theme="light"]) .section-product {
    background: linear-gradient(135deg, #f0f4ff 0%, #ffffff 50%, #f0f4ff 100%);
  }

  /* Light mode: text colours */
  :global([data-theme="light"]) .section-product .text-slate-300 {
    color: #475569 !important;
  }

  .product-img-wrap {
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4/3;
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition:
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  :global([data-theme="light"]) .product-img-wrap {
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.1),
      0 0 0 1px rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .product-img-wrap:hover {
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.6),
      0 0 0 2px rgba(59, 130, 246, 0.4);
    transform: scale(1.02);
  }

  :global([data-theme="light"]) .product-img-wrap:hover {
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.15),
      0 0 0 2px rgba(29, 78, 216, 0.3);
  }
</style>
