                                    const bulletColor = isSimpleString ? (cardDefaults?.feature?.bulletColor || finalIconColor) : (feature.bulletColor || cardDefaults?.feature?.bulletColor || finalIconColor);
                                    const badges = isSimpleString ? [] : (feature.badges || []);
                                    
                                    return (
