---
export interface Props {
  sectionId: string;
  sectionType?: string;
  content: string;
  backgroundImage: string;
  minHeight?: string;
  logo?: string;
  language?: string;
  overlayOpacity?: string; // e.g. "0.35", "0.55" — controls how dark the image overlay is
  sectionContent?: {
    title?: string;
    description?: string;
    companyName?: string;
    companyNameHighlight?: string;
    buttonText?: string;
  };
}

const {
  sectionId,
  sectionType = sectionId,
  backgroundImage,
  minHeight = "560px",
  logo = "",
  language = "en",
  overlayOpacity,
  sectionContent = {},
} = Astro.props;

const overlayStyle = `background: rgba(0, 0, 0, ${overlayOpacity ?? "0.55"})`;

const heading = sectionContent.title || "";
const description = sectionContent.description || "";
const buttonText = sectionContent.buttonText || "";
const companyName = sectionContent.companyName || "Evolver";
const companyHL = sectionContent.companyNameHighlight || "AI";

const normalised = description
  .replace(/[\r\n]+/g, " ")
  .replace(/\s+/g, " ")
  .trim();

const processed = normalised.replace(
  new RegExp(`${companyName}${companyHL}`, "g"),
  `${companyName}<span class="text-blue-400">${companyHL}</span>`,
);
---

<section
  id={sectionId}
  class="relative bg-center bg-cover flex items-center"
  style={`background-image: url('${backgroundImage}'); min-height: ${minHeight};`}
  data-section={sectionType}
>
  <!-- Dark overlay — configurable opacity -->
  <div class="absolute inset-0" style={overlayStyle}></div>

  <!-- Content panel — right-aligned glass card, full-width on mobile -->
  <div
    class="relative z-10 container mx-auto px-4 py-12 md:py-16 flex justify-center md:justify-end"
  >
    <div class="reveal-left w-full max-w-lg">
      <div class="content-panel text-left md:text-right">
        {
          logo && (
            <div class="mb-4 flex justify-end">
              <img
                src={logo}
                alt="Company logo"
                class="h-12 max-w-[180px] object-contain"
                loading="lazy"
              />
            </div>
          )
        }
        {
          heading && (
            <h2 class="text-3xl font-bold text-white mb-4 leading-tight">
              {heading}
            </h2>
          )
        }

        <div class="divider-orange"></div>

        <p
          class="text-slate-200 text-lg leading-relaxed my-4"
          set:html={processed}
        />

        <div class="divider-orange"></div>

        {
          buttonText && (
            <button class="btn btn-primary mt-4">{buttonText}</button>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .content-panel {
    background: rgba(10, 15, 30, 0.82);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(148, 163, 184, 0.15);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow:
      0 0 60px rgba(0, 0, 0, 0.5),
      0 24px 48px rgba(0, 0, 0, 0.4);
  }

  /* In light mode the panel stays dark — it sits over a photo so contrast must be preserved */
  :global([data-theme="light"]) .content-panel {
    background: rgba(10, 15, 30, 0.78);
  }
</style>
