---
// Shared card content renderer — features (with rich icon+title mode),
// subsections, callout, note, button, link.
// Used by Card.astro in all layout variants to avoid duplicated rendering code.

export interface Props {
    features?: any[];
    subtitle?: string;
    subsections?: Array<{
        title?: string;
        icon?: string;
        description?: string;
        features?: any[];
    }>;
    subsectionColumns?: number;
    subsectionStyle?: string; // 'plain' | 'card'
    callout?: { icon?: string; title?: string; text: string };
    note?: { title: string; content: string; signature?: string } | string;
    buttonText?: string;
    buttonUrl?: string;
    buttonColor?: string;
    linkText?: string;
    linkUrl?: string;
    theme?: string;
    // Computed styling from parent Card
    featureClasses: string;
    bulletSize: string;
    finalIconColor: string;
    cardDefaults?: any;
}

const {
    features,
    subtitle,
    subsections,
    subsectionColumns = 1,
    subsectionStyle = "plain",
    callout,
    note,
    buttonText,
    buttonUrl,
    buttonColor = "bg-blue-600 hover:bg-blue-700",
    linkText,
    linkUrl,
    theme = "dark",
    featureClasses,
    bulletSize,
    finalIconColor,
    cardDefaults,
} = Astro.props;

const subsectionColClass =
    subsectionColumns === 3
        ? "grid-cols-1 md:grid-cols-3"
        : subsectionColumns === 2
          ? "grid-cols-1 md:grid-cols-2"
          : "grid-cols-1";
---

{
    subtitle && (
        <h3 class="text-blue-400 font-semibold text-lg mb-3">{subtitle}</h3>
    )
}

{
    features && features.length > 0 && (
        <ul class={`${featureClasses} mb-4 text-left`}>
            {features.map((feature: any) => {
                const isSimpleString = typeof feature === "string";
                const featureText = isSimpleString ? feature : feature.text;
                const featureTitle = !isSimpleString
                    ? feature.title
                    : undefined;
                const featureIcon = !isSimpleString ? feature.icon : undefined;
                const bullet = isSimpleString
                    ? cardDefaults?.feature?.bullet || "•"
                    : feature.bullet || cardDefaults?.feature?.bullet || "•";
                const bulletType = isSimpleString
                    ? cardDefaults?.feature?.bulletType || "symbol"
                    : feature.bulletType ||
                      cardDefaults?.feature?.bulletType ||
                      "symbol";
                const bulletColor = isSimpleString
                    ? cardDefaults?.feature?.bulletColor || finalIconColor
                    : feature.bulletColor ||
                      cardDefaults?.feature?.bulletColor ||
                      finalIconColor;
                const badges = isSimpleString ? [] : feature.badges || [];
                return featureTitle ? (
                    // Rich mode: material icon + bold title + description paragraph
                    <li class="flex items-start gap-3 mb-4">
                        {featureIcon && (
                            <span class="material-icons text-yellow-300 mt-1 flex-shrink-0">
                                {featureIcon}
                            </span>
                        )}
                        <div>
                            <h6 class="font-semibold card-title text-sm mb-1">
                                {featureTitle}
                            </h6>
                            <p class={featureClasses}>{featureText}</p>
                        </div>
                    </li>
                ) : (
                    // Standard bullet mode — unchanged from original
                    <li class="flex items-start mb-2 text-left">
                        {bulletType === "icon" ? (
                            <span
                                class={`material-icons ${bulletColor} mr-2 ${bulletSize} flex-shrink-0`}
                            >
                                {bullet}
                            </span>
                        ) : bulletType === "dot" ? (
                            <span
                                class={`inline-block w-2 h-2 rounded-full ${bulletColor.replace("text-", "bg-")} mr-3 mt-1 flex-shrink-0`}
                            />
                        ) : (
                            <span
                                class={`${bulletColor} mr-2 font-bold flex-shrink-0`}
                            >
                                {bullet}
                            </span>
                        )}
                        <div class="flex-1 text-left">
                            <div class="flex items-start gap-2 flex-wrap">
                                <span class={`flex-1 ${featureClasses}`}>
                                    {featureText}
                                </span>
                                {badges.length > 0 && (
                                    <div class="flex gap-1 flex-wrap">
                                        {badges.map((badge: any) => (
                                            <span
                                                class={`inline-block px-2 py-1 text-xs font-medium text-white rounded-full ${badge.color} whitespace-nowrap`}
                                                title={
                                                    badge.tooltip || badge.text
                                                }
                                            >
                                                {badge.text}
                                            </span>
                                        ))}
                                    </div>
                                )}
                            </div>
                        </div>
                    </li>
                );
            })}
        </ul>
    )
}

{
    subsections && subsections.length > 0 && (
        <div class={`grid ${subsectionColClass} gap-4 mt-4`}>
            {subsections.map((sub: any) => (
                <div
                    class={
                        subsectionStyle === "card"
                            ? "bg-slate-700/60 rounded-lg p-4"
                            : ""
                    }
                >
                    {sub.title && (
                        <h4
                            class={`font-semibold mb-3 text-sm flex items-center gap-2 ${sub.icon ? "card-title" : "text-yellow-300"}`}
                        >
                            {sub.icon && (
                                <span class="material-icons text-yellow-300">
                                    {sub.icon}
                                </span>
                            )}
                            {sub.title}
                        </h4>
                    )}
                    {sub.description && (
                        <p class={`${featureClasses} mb-3`}>
                            {sub.description}
                        </p>
                    )}
                    {sub.features && sub.features.length > 0 && (
                        <ul class={`${featureClasses} space-y-3`}>
                            {sub.features.map((feat: any) => {
                                const isSimple = typeof feat === "string";
                                const text = isSimple ? feat : feat.text;
                                const fIcon = !isSimple ? feat.icon : undefined;
                                const fTitle = !isSimple
                                    ? feat.title
                                    : undefined;
                                return fTitle ? (
                                    <li class="flex items-start gap-3">
                                        {fIcon && (
                                            <span class="material-icons text-yellow-300 mt-1 flex-shrink-0">
                                                {fIcon}
                                            </span>
                                        )}
                                        <div>
                                            <h6 class="font-semibold text-white mb-0.5 text-sm">
                                                {fTitle}
                                            </h6>
                                            <p class={featureClasses}>{text}</p>
                                        </div>
                                    </li>
                                ) : (
                                    <li class="flex items-start gap-2">
                                        <span
                                            class={`${finalIconColor} flex-shrink-0 font-bold mt-0.5`}
                                        >
                                            •
                                        </span>
                                        <span>{text}</span>
                                    </li>
                                );
                            })}
                        </ul>
                    )}
                </div>
            ))}
        </div>
    )
}

{
    callout && (
        <div class="mt-4 bg-blue-900/30 rounded-lg p-4 border border-blue-800/40">
            <div class="flex items-start gap-3">
                {callout.icon && (
                    <span class="material-icons text-blue-400 text-2xl mt-0.5 flex-shrink-0">
                        {callout.icon}
                    </span>
                )}
                <div>
                    {callout.title && (
                        <h4 class="font-semibold text-blue-300 mb-1 text-sm">
                            {callout.title}
                        </h4>
                    )}
                    <p class={featureClasses}>{callout.text}</p>
                </div>
            </div>
        </div>
    )
}

{
    note &&
        (typeof note === "string" ? (
            <div class="mt-4 flex items-center gap-2 text-sm text-gray-300">
                <span class="material-icons text-blue-400 text-base">info</span>
                <span>{note}</span>
            </div>
        ) : (
            <div class="mt-6 p-4 bg-slate-700 rounded-lg border-l-4 border-blue-400">
                <h4 class="text-blue-300 font-semibold text-sm mb-2">
                    {note.title}
                </h4>
                <blockquote class="text-gray-300 italic text-sm leading-relaxed mb-2">
                    "{note.content}"
                </blockquote>
                {note.signature && (
                    <p class="text-blue-300 text-xs font-medium">
                        {note.signature}
                    </p>
                )}
            </div>
        ))
}

{
    buttonText && buttonUrl && (
        <a
            href={buttonUrl}
            class={`inline-block card-btn ${buttonColor} text-white py-3 px-6 rounded-lg transition duration-300`}
        >
            {buttonText}
        </a>
    )
}

{
    linkText && linkUrl && (
        <a
            href={linkUrl}
            class={
                theme === "dark"
                    ? "text-blue-400 hover:text-blue-300"
                    : "mt-3 px-4 py-1.5 bg-blue-600 text-white rounded-full hover:bg-blue-700 transition-colors duration-300 text-sm font-medium inline-flex items-center"
            }
        >
            {linkText}
            {theme === "light" && (
                <span class="material-icons ml-1 text-xs">arrow_forward</span>
            )}
            {theme === "dark" && " →"}
        </a>
    )
}
