---
// Reusable Cards Section component
import Card from "./Card.astro";

export interface CardData {
    title: string;
    description: string;
    badges?: Array<{ text: string; color: string; tooltip?: string }>;
    icon?: string;
    features?: string[];
    note?: { title: string; content: string; signature?: string } | string;
    linkText?: string;
    linkUrl?: string;
    buttonText?: string;
    buttonUrl?: string;
    buttonColor?: string;
}

export interface Props {
    // Section identification
    sectionId: string;
    sectionType?: string;

    // Content
    title?: string;
    subtitle?: string;
    description?: string;
    image?: string;
    cards: CardData[];
    buttonText?: string;
    buttonUrl?: string;
    buttonColor?: string;

    // Layout
    columns?: string;
    responsiveColumns?: {
        mobile?: string;
        tablet?: string;
        desktop?: string;
    };
    alignment?: string; // "left" (default), "center", "right"

    // Styling
    theme?: string;
    backgroundColor?: string;
    cardTheme?: string;
    iconColor?: string;
    centerCards?: boolean;
    customClasses?: string;
    cardVariant?: "default" | "glass" | "bordered" | "flat" | "feature";

    // Pre-loaded defaults from layout
    defaults?: any;

    // Localization
    language?: string;
}

const {
    sectionId,
    sectionType = sectionId,
    title,
    subtitle,
    description,
    image,
    cards,
    buttonText,
    buttonUrl,
    buttonColor = "bg-blue-600 hover:bg-blue-700",
    columns = "4",
    responsiveColumns,
    alignment = "left",
    theme = "dark",
    backgroundColor = "bg-custom-slate",
    cardTheme,
    iconColor,
    centerCards = true,
    customClasses = "",
    cardVariant = "default",
    defaults = {},
    language = "en",
} = Astro.props;

// Content is passed in directly — no fetching needed
const localizedTitle = title;
const localizedSubtitle = subtitle;
const localizedImage = image;
const localizedButtonText = buttonText;
const localizedButtonUrl = buttonUrl;
const localizedButtonColor = buttonColor;
const localizedBackground = backgroundColor;
const localizedAlignment = alignment;
const localizedResponsiveColumns =
    responsiveColumns || defaults?.cards?.responsiveColumns;

let localizedDescription = description
    ? String(description)
          .replace(/\r\n|\r|\n/g, " ")
          .replace(/\s+/g, " ")
          .trim()
    : "";

let localizedCards = (cards || []).map((card: any) => ({
    ...card,
    description: card.description ? String(card.description).trim() : "",
}));

// Generate responsive grid classes
const defaultResponsive = {
    mobile: "1",
    tablet: columns === "4" ? "2" : columns === "3" ? "2" : columns,
    desktop: columns,
};

const responsive = { ...defaultResponsive, ...localizedResponsiveColumns };

// Ensure all values are strings for class generation
const responsiveStrings = {
    mobile: String(responsive.mobile || "1"),
    tablet: String(responsive.tablet || "2"),
    desktop: String(responsive.desktop || "3"),
};

const gridClasses = `grid grid-cols-${responsiveStrings.mobile} md:grid-cols-${responsiveStrings.tablet} xl:grid-cols-${responsiveStrings.desktop} gap-6`;

// Final card theme (inherit from section if not specified)
const finalCardTheme = cardTheme || theme;

// Title styling based on theme
const titleClasses = theme === "dark" ? "text-white" : "text-gray-800";

const descriptionClasses = theme === "dark" ? "text-gray-300" : "text-gray-600";

// Alignment classes for text content
const alignmentClasses = {
    left: "text-left items-start",
    center: "text-center items-center",
    right: "text-right items-end",
};
const contentAlignment =
    alignmentClasses[localizedAlignment] || alignmentClasses.left;
---

<section
    id={sectionId}
    class={`relative bg-custom-slate py-20 ${customClasses}`}
    data-section={sectionType}
>
    <div class="container mx-auto px-4">
        <!-- Section header -->
        <div class={`flex flex-col ${contentAlignment} mb-12 reveal`}>
            {
                localizedTitle && (
                    <h2
                        class="h1-noto-sans mb-3"
                        transition:name={`section-title-${sectionId}`}
                    >
                        {localizedTitle}
                    </h2>
                )
            }
            {
                localizedSubtitle && (
                    <h3 class="text-2xl font-semibold text-white mb-3">
                        {localizedSubtitle}
                    </h3>
                )
            }
            {
                localizedImage && (
                    <div class="mb-4 flex justify-center">
                        <img
                            src={localizedImage}
                            alt={localizedTitle || ""}
                            class="max-w-xs h-auto object-contain"
                        />
                    </div>
                )
            }
            {
                localizedDescription && (
                    <p class="text-slate-300 text-lg max-w-3xl leading-relaxed mb-4">
                        {localizedDescription}
                    </p>
                )
            }
            {
                localizedButtonText && localizedButtonUrl && (
                    <a
                        href={localizedButtonUrl}
                        class={`btn ${localizedButtonColor} text-white`}
                    >
                        {localizedButtonText}
                    </a>
                )
            }
        </div>

        <!-- Cards grid: horizontal scroll on mobile (multi-card), full-width on mobile (single card), grid on tablet+ -->
        {localizedCards.length === 1 ? (
            <div class="md:hidden">
                <Card
                    title={localizedCards[0].title}
                    description={localizedCards[0].description}
                    badges={localizedCards[0].badges}
                    icon={localizedCards[0].icon}
                    features={localizedCards[0].features}
                    subtitle={localizedCards[0].subtitle}
                    subsections={localizedCards[0].subsections}
                    subsectionColumns={localizedCards[0].subsectionColumns}
                    subsectionStyle={localizedCards[0].subsectionStyle}
                    callout={localizedCards[0].callout}
                    note={localizedCards[0].note}
                    linkText={localizedCards[0].linkText}
                    linkUrl={localizedCards[0].linkUrl}
                    buttonText={localizedCards[0].buttonText}
                    buttonUrl={localizedCards[0].buttonUrl}
                    buttonColor={localizedCards[0].buttonColor}
                    theme={finalCardTheme}
                    iconColor={iconColor}
                    centerContent={centerCards}
                    defaults={defaults?.cards}
                    language={language}
                    variant={cardVariant}
                />
            </div>
        ) : (
        <div class="cards-mobile-scroll md:hidden">
            <div class="cards-scroll-inner">
                {
                    localizedCards.map((card) => (
                        <div class="cards-scroll-item">
                            <Card
                                title={card.title}
                                description={card.description}
                                badges={card.badges}
                                icon={card.icon}
                                features={card.features}
                                subtitle={card.subtitle}
                                subsections={card.subsections}
                                subsectionColumns={card.subsectionColumns}
                                subsectionStyle={card.subsectionStyle}
                                callout={card.callout}
                                note={card.note}
                                linkText={card.linkText}
                                linkUrl={card.linkUrl}
                                buttonText={card.buttonText}
                                buttonUrl={card.buttonUrl}
                                buttonColor={card.buttonColor}
                                theme={finalCardTheme}
                                iconColor={iconColor}
                                centerContent={centerCards}
                                defaults={defaults?.cards}
                                language={language}
                                variant={cardVariant}
                            />
                        </div>
                    ))
                }
            </div>
        </div>
        )}
        <!-- Normal grid on tablet+ -->
        <div class={`hidden md:grid ${gridClasses} stagger`}>
            {
                localizedCards.map((card) => (
                    <Card
                        title={card.title}
                        description={card.description}
                        badges={card.badges}
                        icon={card.icon}
                        features={card.features}
                        subtitle={card.subtitle}
                        subsections={card.subsections}
                        subsectionColumns={card.subsectionColumns}
                        subsectionStyle={card.subsectionStyle}
                        callout={card.callout}
                        note={card.note}
                        linkText={card.linkText}
                        linkUrl={card.linkUrl}
                        buttonText={card.buttonText}
                        buttonUrl={card.buttonUrl}
                        buttonColor={card.buttonColor}
                        theme={finalCardTheme}
                        iconColor={iconColor}
                        centerContent={centerCards}
                        defaults={defaults?.cards}
                        language={language}
                        variant={cardVariant}
                    />
                ))
            }
        </div>
    </div>
</section>

<style>
    .cards-mobile-scroll {
        margin: 0 -1rem; /* bleed to screen edges */
        padding: 0 1rem;
    }
    .cards-scroll-inner {
        display: flex;
        gap: 1rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding-bottom: 1rem; /* space for scroll indicator */
    }
    .cards-scroll-inner::-webkit-scrollbar {
        display: none;
    }
    .cards-scroll-item {
        flex: 0 0 85vw;
        max-width: 320px;
        scroll-snap-align: start;
    }
</style>
