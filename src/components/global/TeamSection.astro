---
export interface TeamMember {
    name: string;
    role: string;
    bio?: string;
    avatar?: string;
    linkedIn?: string;
    twitter?: string;
}

export interface Props {
    sectionId?: string;
    title?: string;
    description?: string;
    members?: TeamMember[];
    language?: string;
}

const {
    sectionId = "team",
    title = "Meet the Team",
    description = "",
    members = [],
    language = "en",
} = Astro.props;

function initials(name: string) {
    return name
        .split(" ")
        .slice(0, 2)
        .map((w) => w[0])
        .join("")
        .toUpperCase();
}

// Consistent bg colours derived from name
const bgPalette = [
    "bg-blue-700",
    "bg-violet-700",
    "bg-teal-700",
    "bg-rose-700",
    "bg-amber-700",
    "bg-emerald-700",
];
---

<section
    id={sectionId}
    class="relative bg-custom-slate py-20 px-4"
    data-section="team"
>
    <div class="container mx-auto">
        {
            (title || description) && (
                <div class="text-center mb-12 reveal-fade">
                    {title && (
                        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                            {title}
                        </h2>
                    )}
                    {description && (
                        <p class="text-lg text-slate-400 max-w-xl mx-auto">
                            {description}
                        </p>
                    )}
                </div>
            )
        }

        <div
            class={`grid gap-8 ${
                members.length <= 2
                    ? "grid-cols-2 max-w-lg mx-auto"
                    : members.length === 3
                      ? "md:grid-cols-3 max-w-3xl mx-auto"
                      : "sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
            }`}
        >
            {
                members.map((member, i) => {
                    const bg = bgPalette[i % bgPalette.length];
                    return (
                        <div
                            class="group relative bg-slate-800/60 border border-slate-700 rounded-2xl overflow-hidden text-center reveal"
                            style={`--stagger-i:${i}`}
                        >
                            {/* Avatar */}
                            <div class="pt-8 pb-4 px-4">
                                {member.avatar ? (
                                    <img
                                        src={member.avatar}
                                        alt={member.name}
                                        width="96"
                                        height="96"
                                        class="w-24 h-24 rounded-full object-cover mx-auto ring-4 ring-slate-700"
                                        loading="lazy"
                                    />
                                ) : (
                                    <div
                                        class={`w-24 h-24 rounded-full mx-auto ring-4 ring-slate-700 flex items-center justify-center text-2xl font-bold text-white ${bg}`}
                                    >
                                        {initials(member.name)}
                                    </div>
                                )}
                            </div>

                            {/* Info */}
                            <div class="px-5 pb-6">
                                <h3 class="font-bold text-white text-base">
                                    {member.name}
                                </h3>
                                <p class="text-blue-400 text-sm mt-0.5">
                                    {member.role}
                                </p>

                                {/* Bio — visible on hover */}
                                {member.bio && (
                                    <p class="text-slate-400 text-xs mt-3 leading-relaxed max-h-0 overflow-hidden group-hover:max-h-40 transition-all duration-500">
                                        {member.bio}
                                    </p>
                                )}

                                {/* Social links */}
                                {(member.linkedIn || member.twitter) && (
                                    <div class="flex items-center justify-center gap-3 mt-4">
                                        {member.linkedIn && (
                                            <a
                                                href={member.linkedIn}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                aria-label={`${member.name} LinkedIn`}
                                                class="text-slate-500 hover:text-blue-400 transition"
                                            >
                                                <svg
                                                    width="18"
                                                    height="18"
                                                    viewBox="0 0 24 24"
                                                    fill="currentColor"
                                                >
                                                    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46C23.21 24 24 23.23 24 22.28V1.72C24 .77 23.21 0 22.23 0z" />
                                                </svg>
                                            </a>
                                        )}
                                        {member.twitter && (
                                            <a
                                                href={member.twitter}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                aria-label={`${member.name} Twitter/X`}
                                                class="text-slate-500 hover:text-sky-400 transition"
                                            >
                                                <svg
                                                    width="18"
                                                    height="18"
                                                    viewBox="0 0 24 24"
                                                    fill="currentColor"
                                                >
                                                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                                                </svg>
                                            </a>
                                        )}
                                    </div>
                                )}
                            </div>
                        </div>
                    );
                })
            }
        </div>

        {
            members.length === 0 && (
                <p class="text-center text-slate-500">
                    No team members configured yet.
                </p>
            )
        }
    </div>
</section>
