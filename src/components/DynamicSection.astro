---
// Pure, typed render switch. Each section already carries its fully-merged
// fields (see scripts/migrate-content.mjs / the `pages` collection schema), so
// there is no runtime layout/content merge here anymore — just a dispatch on
// `section.type`.
import type { Section } from "../content.config";
import ContentFallback from "./ContentFallback.astro";
import ContentHeaderSection from "./global/ContentHeaderSection.astro";
import CardsSection from "./global/CardsSection.astro";
import ProductSection from "./global/ProductSection.astro";
import HeroSection from "./home/HeroSection.astro";
import DividerSection from "./global/DividerSection.astro";
import BlogSection from "./global/BlogSection.astro";
import TestimonialsSection from "./global/TestimonialsSection.astro";
import FaqSection from "./global/FaqSection.astro";
import StatsSection from "./global/StatsSection.astro";
import PricingSection from "./global/PricingSection.astro";
import TeamSection from "./global/TeamSection.astro";
import CtaBannerSection from "./global/CtaBannerSection.astro";
import VideoSection from "./global/VideoSection.astro";
import GallerySection from "./global/GallerySection.astro";
import TimelineSection from "./global/TimelineSection.astro";
import LogoStripSection from "./global/LogoStripSection.astro";

export interface Props {
    section: Section;
    defaults?: any;
    language?: string;
}

const { section, defaults = {}, language = "en" } = Astro.props;
const id = section.id;
const hidden = section.visible === false;
---

{!hidden && section.type === "hero" && (
    <HeroSection language={language} heroContent={section} />
)}

{!hidden && section.type === "content_header" && (
    <ContentHeaderSection
        sectionId={id}
        sectionType={id}
        backgroundImage={section.backgroundImage || "/img/evolverai-web-brainstorming-bg.jpg"}
        minHeight={section.minHeight || "600px"}
        logo={section.logo || ""}
        content=""
        sectionContent={section}
        overlayOpacity={section.overlayOpacity}
        language={language}
    />
)}

{!hidden && section.type === "cards" && (
    section.cards.length > 0 || section.title || section.description ? (
        <CardsSection
            sectionId={id}
            sectionType={id}
            title={section.title || ""}
            subtitle={section.subtitle}
            description={section.description}
            cards={section.cards}
            buttonText={section.buttonText}
            buttonUrl={section.buttonUrl}
            buttonColor={section.buttonColor}
            responsiveColumns={section.responsiveColumns}
            alignment={section.alignment}
            backgroundColor={section.background}
            cardVariant={section.cardVariant}
            defaults={defaults}
            language={language}
        />
    ) : (
        <ContentFallback sectionId={id} reason={`No content found for section "${id}"`} />
    )
)}

{!hidden && section.type === "product" && (
    section.subtitle || section.description ? (
        <ProductSection
            sectionId={id}
            sectionType={id}
            title=""
            subtitle={section.subtitle || ""}
            description={section.description || ""}
            buttonText={section.buttonText}
            buttonUrl={section.buttonUrl}
            buttonColor={section.buttonColor}
            image={section.image}
            imagePosition={section.imagePosition || "right"}
            language={language}
        />
    ) : (
        <ContentFallback sectionId={id} reason={`No content found for product section "${id}"`} />
    )
)}

{!hidden && section.type === "divider" && (
    <DividerSection
        sectionId={id}
        height={section.height}
        backgroundColor={section.backgroundColor}
        showLine={section.showLine}
        lineColor={section.lineColor}
        lineWidth={section.lineWidth}
    />
)}

{!hidden && section.type === "blog" && (
    <BlogSection
        sectionId={id}
        title={section.title || "Latest News & Insights"}
        description={section.description || ""}
        maxPosts={section.maxPosts ?? 6}
        language={language}
        buttonText={section.buttonText}
        buttonUrl={section.buttonUrl ?? "/blog"}
    />
)}

{!hidden && section.type === "testimonials" && (
    <TestimonialsSection
        sectionId={id}
        title={section.title || "What Our Clients Say"}
        description={section.description || ""}
        testimonials={section.testimonials}
        language={language}
        buttonText={section.buttonText}
        buttonUrl={section.buttonUrl}
        layout={section.layout}
    />
)}

{!hidden && section.type === "faq" && (
    <FaqSection
        sectionId={id}
        title={section.title}
        description={section.description}
        items={section.items}
        layout={section.layout ?? "accordion"}
        language={language}
    />
)}

{!hidden && section.type === "stats" && (
    <StatsSection
        sectionId={id}
        title={section.title}
        description={section.description}
        items={section.items}
        language={language}
    />
)}

{!hidden && section.type === "pricing" && (
    <PricingSection
        sectionId={id}
        title={section.title}
        description={section.description}
        billingToggle={section.billingToggle ?? false}
        plans={section.plans}
        language={language}
    />
)}

{!hidden && section.type === "team" && (
    <TeamSection
        sectionId={id}
        title={section.title}
        description={section.description}
        members={section.members}
        language={language}
    />
)}

{!hidden && section.type === "cta_banner" && (
    <CtaBannerSection
        sectionId={id}
        title={section.title}
        description={section.description}
        primaryCta={section.primaryCta}
        primaryCtaUrl={section.primaryCtaUrl}
        secondaryCta={section.secondaryCta}
        secondaryCtaUrl={section.secondaryCtaUrl}
        backgroundStyle={section.backgroundStyle ?? "gradient"}
        backgroundImage={section.backgroundImage}
        language={language}
    />
)}

{!hidden && section.type === "video" && (
    <VideoSection
        sectionId={id}
        title={section.title}
        description={section.description}
        videoUrl={section.videoUrl}
        thumbnail={section.thumbnail}
        autoplay={section.autoplay ?? false}
        loop={section.loop ?? false}
        language={language}
    />
)}

{!hidden && section.type === "gallery" && (
    <GallerySection
        sectionId={id}
        title={section.title}
        description={section.description}
        images={section.images}
        layout={section.layout ?? "grid"}
        language={language}
    />
)}

{!hidden && section.type === "timeline" && (
    <TimelineSection
        sectionId={id}
        title={section.title}
        description={section.description}
        items={section.items}
        layout={section.layout ?? "vertical"}
        language={language}
    />
)}

{!hidden && section.type === "logo_strip" && (
    <LogoStripSection
        sectionId={id}
        title={section.title}
        logos={section.logos}
        scrolling={section.scrolling ?? true}
        language={language}
    />
)}
