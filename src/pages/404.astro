---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
    title="Page Not Found — EvolverAI"
    description="The page you're looking for doesn't exist."
    language="en"
    page="home"
>
    <Header currentLanguage="en" />

    <main
        class="min-h-screen flex flex-col items-center justify-center px-4 py-24 text-center"
    >
        <!-- Background glow -->
        <div
            class="absolute inset-0 pointer-events-none overflow-hidden"
            aria-hidden="true"
        >
            <div
                class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full blur-3xl opacity-5 bg-blue-600"
            >
            </div>
        </div>

        <div class="relative z-10 max-w-lg mx-auto">
            <!-- 404 number -->
            <div class="reveal mb-6">
                <span
                    class="text-[8rem] font-black leading-none select-none"
                    style="background: linear-gradient(135deg, #1d4ed8 0%, #60a5fa 50%, #818cf8 100%);
                 -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
                >
                    404
                </span>
            </div>

            <!-- Message -->
            <div class="reveal">
                <h1 class="text-3xl font-bold text-white mb-4">
                    Page not found
                </h1>
                <p class="text-slate-400 text-lg leading-relaxed mb-10">
                    The page you're looking for has moved, been deleted, or
                    never existed. Let's get you back on track.
                </p>
            </div>

            <!-- Actions -->
            <div
                class="reveal flex flex-col sm:flex-row items-center justify-center gap-3"
            >
                <a href="/en" class="btn btn-primary w-full sm:w-auto">
                    <i class="material-icons text-base">home</i>
                    Back to Home
                </a>
                <a href="/en#contact" class="btn btn-ghost w-full sm:w-auto">
                    <i class="material-icons text-base">headset_mic</i>
                    Contact Us
                </a>
            </div>

            <!-- Quick links -->
            <div class="reveal mt-12">
                <p class="text-xs text-slate-600 uppercase tracking-wider mb-4">
                    Or explore
                </p>
                <div class="flex flex-wrap justify-center gap-2">
                    {
                        [
                            { href: "/en/b2b", label: "B2B Solutions" },
                            { href: "/en/academy", label: "Academy" },
                            { href: "/en/wfm", label: "Workforce Manager" },
                            { href: "/en/elysia", label: "Elysia AI" },
                            { href: "/en/blog", label: "Blog" },
                        ].map((link) => (
                            <a
                                href={link.href}
                                class="px-3 py-1.5 rounded-full text-sm text-slate-400 hover:text-white border border-white/10 hover:border-white/25 hover:bg-white/5 transition-all duration-200"
                            >
                                {link.label}
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </main>

    <Footer language="en" />
</Layout>
