---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import DynamicSection from "../components/DynamicSection.astro";
import {
    getPageData,
    getPageSections,
    getSectionContent,
    getSectionConfig,
    getDefaults,
} from "../utils/content-loader.js";

export async function getStaticPaths() {
    const LANGUAGES = ["en", "de", "it"];
    const PAGES = ["home", "b2b", "wfm", "elysia", "academy"];
    const paths: any[] = [];

    LANGUAGES.forEach((lang) => {
        PAGES.forEach((page) => {
            paths.push({
                params: { slug: page === "home" ? lang : `${lang}/${page}` },
                props: { language: lang, page },
            });
        });
    });

    return paths;
}

const { language, page } = Astro.props;

const pageData = getPageData(page, language);
const { layout, content } = pageData || { layout: {}, content: {} };

const pageSections = getPageSections(layout);
const defaults = getDefaults(layout);

const meta = content?.meta || {};
const title = meta.title || "EvolverAI";
const description = meta.description || "";

// Draft gate: return 404 in production for draft pages
const pageStatus = layout?.status || 'published';
if (pageStatus === 'draft' && import.meta.env.PROD) {
  return Astro.redirect('/404', 404);
}
---

<Layout title={title} description={description} language={language} page={page}>
    <Header currentLanguage={language} />

    <main id="main-content" class={page === "home" ? "space-y-16" : "space-y-0"}>
        {
            pageSections.map((sectionConfig) => {
                const sectionContent = getSectionContent(
                    content,
                    sectionConfig.section_id,
                );
                const sectionLayout = getSectionConfig(
                    layout,
                    sectionConfig.section_id,
                );
                return (
                    <DynamicSection
                        sectionConfig={sectionConfig}
                        sectionContent={sectionContent}
                        sectionLayout={sectionLayout}
                        defaults={defaults}
                        language={language}
                    />
                );
            })
        }
    </main>

    <Footer language={language} footerContent={content?.footer} />
</Layout>
