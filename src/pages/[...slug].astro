---
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import DynamicSection from "../components/DynamicSection.astro";
import { isLocale, pagePath, type Locale } from "../i18n";

export async function getStaticPaths() {
    const entries = await getCollection("pages");

    return entries.map((entry) => {
        // entry.id is "<locale>/<page>", e.g. "en/home" or "de/b2b"
        const [locale, page] = entry.id.split("/");
        return {
            params: { slug: pagePath(locale as Locale, page).slice(1) }, // strip leading "/"
            props: { entry, locale, page },
        };
    });
}

const { entry, locale, page } = Astro.props;
const data = entry.data;

// Draft gate: return 404 in production for draft pages
if (data.status === "draft" && import.meta.env.PROD) {
    return Astro.redirect("/404", 404);
}

const language = isLocale(locale) ? locale : "en";
const title = data.meta.title;
const description = data.meta.description;

// Per-page design tokens come from the separate `pageDefaults` collection.
const defaultsEntry = await getEntry("pageDefaults", page);
const defaults = defaultsEntry?.data ?? {};
---

<Layout title={title} description={description} language={language} page={page} ogImage={data.meta.ogImage}>
    <Header currentLanguage={language} />

    <main id="main-content" class={page === "home" ? "space-y-16" : "space-y-0"}>
        {data.sections.map((section) => (
            <DynamicSection section={section} defaults={defaults} language={language} />
        ))}
    </main>

    <Footer language={language} footerContent={data.footer} />
</Layout>
