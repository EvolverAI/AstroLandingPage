# ─────────────────────────────────────────────────────────────────────────────
# EvolverAI Landing Page — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Admin Server ──────────────────────────────────────────────────────────────

# Secret token for admin API authentication.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production. Optional in local dev (auth is skipped if not set).
ADMIN_TOKEN=your-secret-token-here

# Admin server port (default: 4322)
# PORT=4322

# ── OpenAI (optional — only needed for AI translation + copy suggestions) ─────

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
# If not set, the Translate and AI Improve features will be disabled.
OPENAI_API_KEY=sk-your-key-here

# ── Contact Form (Netlify Function) ───────────────────────────────────────────

# Email address that receives contact form submissions.
CONTACT_EMAIL=info@evolverai.ch

# Resend.com API key for sending contact form emails.
# Free tier: 3,000 emails/month. Get one at https://resend.com
RESEND_API_KEY=re_your-key-here

# ── Site ──────────────────────────────────────────────────────────────────────

# Base URL for canonical links and OG tags (no trailing slash).
# PUBLIC_SITE_URL=https://evolverai.ch

# ── Node ──────────────────────────────────────────────────────────────────────

# Set to 'production' for production builds. Astro sets this automatically.
# NODE_ENV=development
