#!/bin/sh
# EvolverAI pre-push hook
# Type-checks the project and validates content against the Zod schema before push.

echo "🔍 Running astro check (types + content schema)..."
npx astro check

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Push blocked: fix the errors above before pushing."
  echo "   Run 'npm run check' for details."
  exit 1
fi

echo "✅ Check passed — proceeding with push."
