#!/bin/sh
# EvolverAI pre-push hook
# Runs content validation and build check before every push.

echo "🔍 Running content validation..."
node scripts/validate.js

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Push blocked: fix content errors above before pushing."
  echo "   Run 'npm run validate' for details."
  exit 1
fi

echo "✅ Content valid — proceeding with push."
