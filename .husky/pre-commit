#!/bin/sh
# EvolverAI pre-commit hook
# Type-checks the project and validates all content against the Zod schema in
# src/content.config.ts (astro check does both). Install: npm run prepare.

echo "🔍 Running astro check (types + content schema)..."
npx astro check

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Commit blocked: fix the errors above before committing."
  echo "   Run 'npm run check' for details."
  exit 1
fi

echo "✅ Check passed — proceeding with commit."
